{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gb-verify",
  "version": "0.1.0",
  "identifier": "com.humanmusic.gb-verify",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "gb-verify",
        "width": 720,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
