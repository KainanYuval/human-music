{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Human Music",
  "version": "0.1.0",
  "identifier": "com.humanmusic.gb-verify",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Human Music",
        "width": 520,
        "height": 680,
        "minWidth": 400,
        "minHeight": 520,
        "resizable": true,
        "backgroundColor": "#6eb0d8"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
